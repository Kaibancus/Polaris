<UserControl x:Class="DesktopPanel.Views.RadialIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             RenderTransformOrigin="0.5,0.5"
             Cursor="Hand">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
    </UserControl.RenderTransform>

    <Grid>
        <Border Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                Background="#08FFFFFF"
                Padding="8">
            <Border.Effect>
                <DropShadowEffect x:Name="Glow" Color="{Binding GlowColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  BlurRadius="0" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
            <Image Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   RenderOptions.EdgeMode="Aliased"
                   Source="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Border>

        <!-- Running indicator: a square border washed with a flowing blue light.
             A bright spot in the gradient sweeps around the edge (driven by a
             rotating RelativeTransform in code-behind). Hidden unless running.
             No bitmap effect here so the sweep stays GPU-composited and smooth;
             the soft glow is provided by a separate static blurred border. -->
        <Border x:Name="RunningGlowBorder"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                BorderThickness="2.5"
                BorderBrush="#3FA9FF"
                Opacity="0"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Effect>
                <BlurEffect Radius="10"/>
            </Border.Effect>
        </Border>
        <Border x:Name="RunningBorder"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                BorderThickness="2.5"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform x:Name="RunningSweep" CenterX="0.5" CenterY="0.5" Angle="0"/>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#103DA9FF" Offset="0.0"/>
                    <GradientStop Color="#6657C8FF" Offset="0.28"/>
                    <GradientStop Color="#FF6FD3FF" Offset="0.5"/>
                    <GradientStop Color="#6657C8FF" Offset="0.72"/>
                    <GradientStop Color="#103DA9FF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <!-- Name label. Hosted on a zero-size Canvas so it never affects the
             icon's measured size / centering. Positioned + sized in code-behind.
             Hidden by default, fades in on hover. -->
        <Canvas IsHitTestVisible="False">
            <Border x:Name="LabelChrome"
                    Opacity="0"
                    Background="#CC1A1A1A"
                    CornerRadius="7"
                    Padding="8,3"
                    Panel.ZIndex="50">
                <TextBlock x:Name="Label"
                           Text="{Binding DisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="12.5"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"/>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
