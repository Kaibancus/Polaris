<UserControl x:Class="Polaris.Views.RadialIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             RenderTransformOrigin="0.5,0.5"
             Cursor="Hand">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
    </UserControl.RenderTransform>

    <Grid>
        <!-- Soft blue hover glow (Saturn theme). A blurred tinted plate that
             blooms gently BEHIND the icon on hover, so the icon's background
             tile reads as glowing while the icon image itself stays crisp. Its
             colour/alpha is set in code-behind from the accent colour (kept
             faint). Hidden for the liquid-glass theme, which uses the
             water-droplet lens above. Drawn first => sits behind everything. -->
        <Border x:Name="BlueGlow"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="13"
                Opacity="0"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Effect>
                <BlurEffect Radius="16"/>
            </Border.Effect>
            <Border.CacheMode>
                <BitmapCache/>
            </Border.CacheMode>
        </Border>

        <Border x:Name="IconPlate"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                Background="#08FFFFFF"
                Padding="8">
            <Image Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   RenderOptions.EdgeMode="Aliased"
                   Source="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Border>

        <!-- Crystal sheen overlay (liquid-glass theme only). A diagonal glossy
             highlight sweeping across the top-left plus a faint specular dot,
             giving the otherwise near-invisible plate a "晶莹剔透" crystal feel.
             Sits above the icon image but below the hover lens. Made visible and
             populated in code-behind only for the droplet (glass) theme. -->
        <Border x:Name="PlateSheen"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>

        <!-- Water-droplet lens shown on hover. Sits ON TOP of the icon and reads
             as a bead of water magnifying it (the parent 1.7x zoom does the
             magnifying): a faint domed refraction tint, a wet rim catching light
             on the top-left, a soft specular shine and a small focused caustic at
             the lower-right. Only Opacity is animated (the blurs are rasterised
             via BitmapCache) so it stays GPU-composited. -->
        <Grid x:Name="HoverGlow"
              Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Opacity="0"
              IsHitTestVisible="False">
            <Grid.CacheMode>
                <BitmapCache/>
            </Grid.CacheMode>
            <!-- Domed refraction tint: bright near the top where the droplet
                 surface faces the light, fading to clear, with a faint cool
                 shade pooling at the base. -->
            <Border CornerRadius="13">
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.36,0.28" Center="0.36,0.28"
                                         RadiusX="0.95" RadiusY="0.95">
                        <GradientStop Color="#52FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#1EFFFFFF" Offset="0.4"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.72"/>
                        <GradientStop Color="#1A8FB6E8" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
            <!-- Wet rim: a bright hairline around the bead, strongest top-left. -->
            <Border CornerRadius="13" BorderThickness="1.4">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E8FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#30FFFFFF" Offset="0.45"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.6"/>
                        <GradientStop Color="#80D8ECFF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
            <!-- Specular shine: the bright soft dot on the droplet's shoulder. -->
            <Ellipse x:Name="DropletShine"
                     Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.32,0.24" Center="0.32,0.24"
                                         RadiusX="0.26" RadiusY="0.2">
                        <GradientStop Color="#E0FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#50FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="3"/>
                </Ellipse.Effect>
            </Ellipse>
            <!-- Focused caustic: a faint bright pool at the lower-right where
                 light refracts through the bead. -->
            <Ellipse Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.72,0.78" Center="0.72,0.78"
                                         RadiusX="0.3" RadiusY="0.26">
                        <GradientStop Color="#3CFFFFFF" Offset="0.0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="5"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Running indicator: a square border washed with a flowing blue light.
             A bright spot in the gradient sweeps around the edge (driven by a
             rotating RelativeTransform in code-behind). Hidden unless running.
             No bitmap effect here so the sweep stays GPU-composited and smooth;
             the soft glow is provided by a separate static blurred border. -->
        <Border x:Name="RunningGlowBorder"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                BorderThickness="2.5"
                BorderBrush="#3FA9FF"
                Opacity="0"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Effect>
                <BlurEffect Radius="10"/>
            </Border.Effect>
            <!-- Rasterise the blurred ring once so the breathing Opacity pulse is
                 a pure GPU composite (no per-frame blur recompute). -->
            <Border.CacheMode>
                <BitmapCache/>
            </Border.CacheMode>
        </Border>
        <Border x:Name="RunningBorder"
                Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                BorderThickness="2.5"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform x:Name="RunningSweep" CenterX="0.5" CenterY="0.5" Angle="0"/>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#103DA9FF" Offset="0.0"/>
                    <GradientStop Color="#6657C8FF" Offset="0.28"/>
                    <GradientStop Color="#FF6FD3FF" Offset="0.5"/>
                    <GradientStop Color="#6657C8FF" Offset="0.72"/>
                    <GradientStop Color="#103DA9FF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <!-- Name label. Hosted on a zero-size Canvas so it never affects the
             icon's measured size / centering. Positioned + sized in code-behind.
             Hidden by default, fades in on hover. -->
        <Canvas IsHitTestVisible="False">
            <Border x:Name="LabelChrome"
                    Opacity="0"
                    Background="#261A1A1A"
                    CornerRadius="7"
                    Padding="8,3"
                    Panel.ZIndex="50">
                <TextBlock x:Name="Label"
                           Text="{Binding DisplayName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{Binding LabelBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="11.5"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"/>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
